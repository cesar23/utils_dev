# ═══════════════════════════════════════════════════════════════════════════════
#  .gitattributes — Configuración universal multi-proyecto
#  Cubre: Web, Node, Python, PHP, Java, Go, Rust, C/C++, C#, Mobile, DevOps
#  Principio: el repo SIEMPRE guarda LF. Windows recibe lo que necesita al checkout.
# ═══════════════════════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────────────────────
#  REGLA BASE
#  text=auto  → Git detecta si es texto y normaliza LF al hacer commit.
#               Es la única línea indispensable. Todo lo demás es refinamiento.
# ───────────────────────────────────────────────────────────────────────────────
* text=auto eol=lf


# ═══════════════════════════════════════════════════════════════════════════════
#  SECCIÓN 1 — SCRIPTS Y ARCHIVOS DE SISTEMA OPERATIVO
#  Los .bat/.cmd DEBEN tener CRLF para ejecutarse en Windows.
#  Los .sh/.bash DEBEN tener LF para ejecutarse en Unix/Linux/Mac/Docker.
# ═══════════════════════════════════════════════════════════════════════════════

# Windows — siempre CRLF (requerido por el intérprete de Windows)
*.bat           text eol=crlf
*.cmd           text eol=crlf
*.ps1           text eol=crlf
*.psm1          text eol=crlf
*.psd1          text eol=crlf

# Unix/Linux/Mac/Docker — siempre LF
*.sh            text eol=lf
*.bash          text eol=lf
*.zsh           text eol=lf
*.fish          text eol=lf
*.ksh           text eol=lf
Makefile        text eol=lf
makefile        text eol=lf
*.mk            text eol=lf
Dockerfile      text eol=lf
*.dockerfile    text eol=lf


