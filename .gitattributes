# ═══════════════════════════════════════════════════════════════════════════════
#  SECCIÓN 8 — EXPORT-IGNORE
#  Archivos que NO se incluyen en git archive / zip exports del repo.
# ═══════════════════════════════════════════════════════════════════════════════

.gitattributes          export-ignore
.gitignore              export-ignore
.gitmodules             export-ignore
.github/                export-ignore
.gitlab-ci.yml          export-ignore
.travis.yml             export-ignore
.editorconfig           export-ignore
.eslintrc*              export-ignore
.prettierrc*            export-ignore
*.test.*                export-ignore
tests/                  export-ignore
__tests__/              export-ignore
spec/                   export-ignore
docs/                   export-ignore
node_modules/           export-ignore
dist/                   export-ignore
build/                  export-ignore
coverage/               export-ignore
.env                    export-ignore
.env.*                  export-ignore


# ═══════════════════════════════════════════════════════════════════════════════
#  SECCIÓN 9 — MERGE STRATEGIES
#  Archivos generados automáticamente que NO deben tener conflictos de merge.
#  "ours" = en caso de conflicto, mantener la versión de la rama actual.
# ═══════════════════════════════════════════════════════════════════════════════

package-lock.json       merge=ours
yarn.lock               merge=ours
pnpm-lock.yaml          merge=ours
composer.lock           merge=ours
Gemfile.lock            merge=ours
Pipfile.lock            merge=ours
poetry.lock             merge=ours
Cargo.lock              merge=ours


# ═══════════════════════════════════════════════════════════════════════════════
#  CÓMO APLICAR ESTO EN UN REPO EXISTENTE
# ───────────────────────────────────────────────────────────────────────────────
#  1. Copia este archivo a la raíz de tu proyecto como ".gitattributes"
#  2. Ejecuta:
#       git add .gitattributes
#       git add --renormalize .
#       git status              ← muestra los archivos que se normalizarán
#       git commit -m "chore: normalizar saltos de línea a LF"
#       git push
#
#  Config recomendada en tu máquina Windows (una vez):
#       git config --global core.autocrlf input
# ═══════════════════════════════════════════════════════════════════════════════